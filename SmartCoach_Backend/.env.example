# ⚠️ تعليمات التشغيل:
# 1. اعمل نسخة من الملف ده وغير اسمها لـ .env
# 2. امسح الكلام العربي وحط الباسوردات الحقيقية بتاعتك

# لينك قاعدة البيانات السحابية (Neon.tech أو أي PostgreSQL)
NEON_DATABASE_URL="your_database_url_here"

# بيانات الـ API بتاعة ساعة فيتبيت (من موقع Fitbit Developer)
FITBIT_CLIENT_ID="your_client_id_here"
FITBIT_CLIENT_SECRET="your_client_secret_here"