# 1. بنسحب نسخة بايثون خفيفة جداً نعتبرها نظام التشغيل بتاعنا
FROM python:3.9-slim

# 2. بنعمل فولدر جوه الكونتينر اسمه /app ونقوله كل شغلنا هيبقى جواه
WORKDIR /app

# 3. بناخد ملف المكتبات من اللاب توب بتاعك نحطه جوه الكونتينر
COPY requirements.txt .

# 4. بنسطب كل المكتبات دي جوه الكونتينر (بمنع الكاش عشان نوفر مساحة)
RUN pip install --no-cache-dir -r requirements.txt

# 5. بناخد كل ملفات مشروعك (الكود بتاعك كله) نحطه جوه الكونتينر
COPY . .

# 6. ده الأمر اللي الكونتينر هينفذه أول ما يشتغل (بيشغل سيرفر uvicorn)
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8000"]